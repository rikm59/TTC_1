# ============================================================
# Instagram Saves → Notion | Agent Framework — Environment Vars
# ============================================================
# Production URL: https://instagram-saves-agent-framework.onrender.com
#
# Copy this file to .env and fill in real values.
# Never commit .env — it is listed in .gitignore.
# All of these must also be added under the Environment tab
# in your Render dashboard (or render.yaml envVars section).
# ============================================================

# ----------------------------------------------------------
# REQUIRED — Webhook authentication
# Generate a strong random value, e.g.:
#   openssl rand -hex 32
# ----------------------------------------------------------
TRIGGER_SECRET_KEY=CreateYourOwnComplexSecretPassphraseHere

# ----------------------------------------------------------
# OPTIONAL — HTTP port (Render injects PORT automatically)
# Only set locally if 3000 conflicts with another service.
# ----------------------------------------------------------
# PORT=3000

# ----------------------------------------------------------
# engine.js — Instagram Graph API
# Get your token from: https://developers.facebook.com/tools/explorer
# Token must have: instagram_basic, pages_show_list
# ----------------------------------------------------------
INSTAGRAM_ACCESS_TOKEN=your-instagram-graph-api-token-here

# ----------------------------------------------------------
# engine.js — Notion Integration
# 1. Create integration at: https://www.notion.so/profile/integrations
# 2. Share your target database with the integration
# 3. Copy the database ID from the database URL:
#    notion.so/workspace/<DATABASE_ID>?v=...
# ----------------------------------------------------------
NOTION_API_KEY=secret_your-notion-integration-token-here
NOTION_DATABASE_ID=your-32-char-database-id-here

# ID of the "Instagram Accounts" database (created automatically)
NOTION_ACCOUNTS_DATABASE_ID=f11be501dbdf4b399105dc59d49fc5b4

# ----------------------------------------------------------
# Notion database must have these exact property names & types:
#   Name        → Title
#   Post URL    → URL
#   Caption     → Text
#   Author      → Text
#   Thumbnail   → URL
#   Posted At   → Date
# ----------------------------------------------------------
