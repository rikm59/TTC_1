# ============================================================
# Instagram Saves → Notion | Agent Framework — Environment Vars
# ============================================================
# Production URL: https://instagram-saves-agent-framework.onrender.com
#
# Copy this file to .env and fill in real values.
# Never commit .env — it is listed in .gitignore.
# All of these must also be added under the Environment tab
# in your Render dashboard.
# ============================================================

# ----------------------------------------------------------
# REQUIRED — Webhook authentication
# Generate a strong random value, e.g.:
#   openssl rand -hex 32
# ----------------------------------------------------------
TRIGGER_SECRET_KEY=CreateYourOwnComplexSecretPassphraseHere

# ----------------------------------------------------------
# OPTIONAL — HTTP port (Render injects PORT automatically)
# Only set locally if 3000 conflicts with another service.
# ----------------------------------------------------------
# PORT=3000

# ----------------------------------------------------------
# engine.js — Instagram Graph API (via graph.facebook.com)
# 1. Go to: https://developers.facebook.com/tools/explorer
# 2. Select your App, click "Generate Access Token"
# 3. Required permissions: instagram_basic, pages_show_list,
#    pages_read_engagement, instagram_manage_insights
#
# To find your INSTAGRAM_BUSINESS_ACCOUNT_ID:
#   a. In Graph API Explorer, run: GET /me/accounts
#   b. Copy a Page ID from the result
#   c. Run: GET /{page-id}?fields=instagram_business_account
#   d. Copy the "id" value from instagram_business_account
# ----------------------------------------------------------
INSTAGRAM_ACCESS_TOKEN=your-facebook-graph-api-token-here

# ----------------------------------------------------------
# Optional but strongly recommended — Auto token refresh
# Paste your App ID and App Secret from:
#   developers.facebook.com → Your App → App Settings → Basic
# With these set, the token auto-renews on every service restart.
# ----------------------------------------------------------
FB_APP_ID=your-app-id-here
FB_APP_SECRET=your-app-secret-here

# ----------------------------------------------------------
# engine.js — Notion Integration
# 1. Create an integration at: https://www.notion.so/profile/integrations
# 2. Share BOTH databases with the integration in Notion
# 3. Copy the COLLECTION IDs below (not the page IDs from the URL)
# ----------------------------------------------------------
NOTION_API_KEY=secret_your-notion-integration-token-here

# "Instagram Posts" collection ID
NOTION_DATABASE_ID=a9e63dc8-16a6-4cf7-8554-7dc7cfcde933

# "Instagram Accounts" collection ID
NOTION_ACCOUNTS_DATABASE_ID=dbb3afce-fede-4849-8006-9c4e31d129f0

# ----------------------------------------------------------
# The "Instagram Posts" database must have these exact property
# names and types in Notion:
#   Name        → Title
#   Post URL    → URL
#   Caption     → Text
#   Author      → Text
#   Thumbnail   → URL
#   Posted At   → Date
# ----------------------------------------------------------

# ============================================================
# ARCADS — AI Video & Image Generation (arcads.ai)
# ============================================================
# Run ./scripts/setup.sh to be guided through setup.
# Find your credentials at: https://app.arcads.ai/settings/api
# ----------------------------------------------------------

# Option A (recommended): Pre-encoded Basic auth header
# Looks like: Basic ODQxMTg4NDExZDY1NDQ0MmJk...
ARCADS_BASIC_AUTH='Basic your_base64_encoded_credentials_here'

# Option B: API key only (some accounts get 403 — use Option A if so)
# ARCADS_API_KEY=your_key_here

# Optional overrides
# ARCADS_CLIENT_ID=your_client_id_here
# ARCADS_BASE_URL=https://external-api.arcads.ai
